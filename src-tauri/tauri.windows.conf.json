{
  "build": {
    "beforeBundleCommand": {
      "cwd": ".",
      "script": "powershell -ExecutionPolicy Bypass -File ./resources-windows/scripts/Sign-Binaries.ps1"
    }
  },
  "bundle": {
    "resources": [
      "resources-windows/binaries/*",
      "resources-windows/scripts/*",
      "resources/icons/tray/*"
    ],
    "targets": [
      "msi"
    ]
  }
}
